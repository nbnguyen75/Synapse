{
   "name": "synapse-web",
   "description": "Synapse project",
   "private": true,
   "version": "0.0.1",
   "type": "module",
   "lint-staged": {
      "*": "bun --bun check"
   },
   "scripts": {
      "dev": "vite",
      "build": "tsc -b && vite build",
      "postinstall": "bun --bun generate-translation",
      "generate-translation": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide",
      "preview": "vite preview",
      "generate-routes": "tsr generate",
      "lint": "oxlint . && eslint .",
      "format": "prettier --list-different --write .",
      "check": "prettier --list-different --write . && oxlint --fix . && eslint --fix .",
      "prepare": "husky"
   },
